          <ml id="ID1449852883">val hashtablesize = 98764327 (* a prime*)  
fun combine [] = 0  
        | combine (h :: t) = (ord h + 7 * combine t) mod hashtablesize  
fun hash s = combine (explode s) ;
            <layout>(*HASHing*)
(*http://homepages.inf.ed.ac.uk/mfourman/teaching/mlCourse/notes/sml-arrays.html*)

val hashtablesize = 98764327 (* a prime*)  
fun combine [] = 0  
        | combine (h :: t) = (ord h + 7 * combine t) mod hashtablesize  
fun hash s = combine (explode s) ;</layout>
