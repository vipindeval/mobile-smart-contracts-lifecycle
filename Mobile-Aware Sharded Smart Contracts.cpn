          <ml id="ID1450268754">(* Mobile resource constraints (battery/CPU/network) *)
val NET_OFF:int = 0;
val NET_POOR:int = 1;
val NET_GOOD:int = 2;
(* Timed CPN parameters (time units arbitrary) *)
val EDGE_LAT:int = 2;
val BLOCK_TIME:int = 5;
val FINALITY:int = 10;

val COST_BLOCK_BATT:int = 2;
val COST_BLOCK_CPU:int = 3;
val COST_PROOF_BATT:int = 1;
val COST_PROOF_CPU:int = 2;
val COST_ROOT_BATT:int = 1;
val COST_ROOT_CPU:int = 2;

fun enoughRes(res:MRES, db:int, dc:int) =
    ((#batt res) &gt;= db) andalso ((#cpu res) &gt;= dc);

fun decRes(res:MRES, db:int, dc:int) =
    {batt = ((#batt res) - db), cpu = ((#cpu res) - dc), net = (#net res)};
(* === Receipt protocol + contract-state helpers (mobile-sharded smart contracts) === *)
val CS_ACTIVE = &quot;Active&quot;;
val CS_LOCKED = &quot;Locked&quot;;

val N_SHARDS = 4;
fun nextSID sid = (sid + 1) mod N_SHARDS;

val COST_APPLY_BATT = 1;
val COST_APPLY_CPU = 3;
val COST_APPLY_CPU_EDGE = 1;
val CPU_EDGE_TH = 20;

(* Receipt tuple helpers: RECEIPT = (rid,stage,fromCID,toCID,fromSID,toSID,txid,anchorID,anchorHash) *)
fun r_rid   (rid,_,_,_,_,_,_,_,_) = rid;
fun r_stage (_,stg,_,_,_,_,_,_,_) = stg;
fun r_fromCID (_,_,fromCID,_,_,_,_,_,_) = fromCID;
fun r_toCID   (_,_,_,toCID,_,_,_,_,_) = toCID;
fun r_fromSID (_,_,_,_,fromSID,_,_,_,_) = fromSID;
fun r_toSID   (_,_,_,_,_,toSID,_,_,_) = toSID;
fun r_txid    (_,_,_,_,_,_,txid,_,_) = txid;
fun r_anchorID (_,_,_,_,_,_,_,aid,_) = aid;
fun r_anchorHash (_,_,_,_,_,_,_,_,ah) = ah;

fun mkReceipt(rid, stage, fromCID, toCID, fromSID, toSID, txid, anchorID, anchorHash) =
  (rid, stage, fromCID, toCID, fromSID, toSID, txid, anchorID, anchorHash);

fun withStage(r, st) =
  (r_rid r, st, r_fromCID r, r_toCID r, r_fromSID r, r_toSID r, r_txid r, r_anchorID r, r_anchorHash r);

fun receiptRouteSID r =
  if (r_stage r) = &quot;APPLY&quot; then r_fromSID r else r_toSID r;
            <layout>(* Mobile resource constraints (battery/CPU/network) *)
val NET_OFF:int = 0;
val NET_POOR:int = 1;
val NET_GOOD:int = 2;
(* Timed CPN parameters (time units arbitrary) *)
val EDGE_LAT:int = 2;
val BLOCK_TIME:int = 5;
val FINALITY:int = 10;

val COST_BLOCK_BATT:int = 2;
val COST_BLOCK_CPU:int = 3;
val COST_PROOF_BATT:int = 1;
val COST_PROOF_CPU:int = 2;
val COST_ROOT_BATT:int = 1;
val COST_ROOT_CPU:int = 2;

fun enoughRes(res:MRES, db:int, dc:int) =
    ((#batt res) &gt;= db) andalso ((#cpu res) &gt;= dc);

fun decRes(res:MRES, db:int, dc:int) =
    {batt = ((#batt res) - db), cpu = ((#cpu res) - dc), net = (#net res)};
(* === Receipt protocol + contract-state helpers (mobile-sharded smart contracts) === *)
val CS_ACTIVE = &quot;Active&quot;;
val CS_LOCKED = &quot;Locked&quot;;

val N_SHARDS = 4;
fun nextSID sid = (sid + 1) mod N_SHARDS;

val COST_APPLY_BATT = 1;
val COST_APPLY_CPU = 3;
val COST_APPLY_CPU_EDGE = 1;
val CPU_EDGE_TH = 20;

(* Receipt tuple helpers: RECEIPT = (rid,stage,fromCID,toCID,fromSID,toSID,txid,anchorID,anchorHash) *)
fun r_rid   (rid,_,_,_,_,_,_,_,_) = rid;
fun r_stage (_,stg,_,_,_,_,_,_,_) = stg;
fun r_fromCID (_,_,fromCID,_,_,_,_,_,_) = fromCID;
fun r_toCID   (_,_,_,toCID,_,_,_,_,_) = toCID;
fun r_fromSID (_,_,_,_,fromSID,_,_,_,_) = fromSID;
fun r_toSID   (_,_,_,_,_,toSID,_,_,_) = toSID;
fun r_txid    (_,_,_,_,_,_,txid,_,_) = txid;
fun r_anchorID (_,_,_,_,_,_,_,aid,_) = aid;
fun r_anchorHash (_,_,_,_,_,_,_,_,ah) = ah;

fun mkReceipt(rid, stage, fromCID, toCID, fromSID, toSID, txid, anchorID, anchorHash) =
  (rid, stage, fromCID, toCID, fromSID, toSID, txid, anchorID, anchorHash);

fun withStage(r, st) =
  (r_rid r, st, r_fromCID r, r_toCID r, r_fromSID r, r_toSID r, r_txid r, r_anchorID r, r_anchorHash r);

fun receiptRouteSID r =
  if (r_stage r) = &quot;APPLY&quot; then r_fromSID r else r_toSID r;</layout>
