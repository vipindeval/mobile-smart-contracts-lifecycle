          <ml id="ID1450277777">(* Shard-block Generation helper functions: keeps arc inscriptions simple and type-stable *)
fun mkDepositTx(txid:int, mw:Wallet, np:NetworkParameter, mi:MachineIdentity) : Transaction =
  {ID=txid,
   from = #Address mw,
   to = #depositAddress np,
   amount = #minDeposit np,
   pubkey = #pubKey (#KeyPair mi),
   txSig = #privKey (#KeyPair mi)};

fun mkShardBlock(sbid:int, sprev:string, diff:int, txr:Transaction) : Block =
  {ID=sbid,
   prevBlockHash=sprev,
   BlockchainDiffTarget=diff,
   txList=txr::[]};

fun mkShardAnchorTx(sid:int, sbid:int, sprev:string, diff:int, txr:Transaction) : Transaction =
  {ID=sbid,
   from=&quot;Shard&quot; ^ Int.toString sid,
   to=&quot;MainChain&quot;,
   amount=0,
   pubkey=&quot;ANCHOR&quot;,
   txSig=Int.toString(hashBlock(mkShardBlock(sbid,sprev,diff,txr)))};

fun mkMainBlock(bid:int, pHash:string, diff:int, txid:int,
                txr:Transaction, mw:Wallet, np:NetworkParameter,
                mi:MachineIdentity, sid:int, sbid:int, sprev:string) : Block =
  {ID=bid,
   prevBlockHash=pHash,
   BlockchainDiffTarget=diff,
   txList=mkDepositTx(txid,mw,np,mi)::txr::(mkShardAnchorTx(sid,sbid,sprev,diff,txr)::[])};

fun nextMainPrevHash(pHash:string, b:Block) : string =
  pHash ^ Int.toString(hashBlock b);

fun blockHashString(b:Block) : string =
  Int.toString(hashBlock b);
            <layout>(* Shard-block Generation helper functions: keeps arc inscriptions simple and type-stable *)
fun mkDepositTx(txid:int, mw:Wallet, np:NetworkParameter, mi:MachineIdentity) : Transaction =
  {ID=txid,
   from = #Address mw,
   to = #depositAddress np,
   amount = #minDeposit np,
   pubkey = #pubKey (#KeyPair mi),
   txSig = #privKey (#KeyPair mi)};

fun mkShardBlock(sbid:int, sprev:string, diff:int, txr:Transaction) : Block =
  {ID=sbid,
   prevBlockHash=sprev,
   BlockchainDiffTarget=diff,
   txList=txr::[]};

fun mkShardAnchorTx(sid:int, sbid:int, sprev:string, diff:int, txr:Transaction) : Transaction =
  {ID=sbid,
   from=&quot;Shard&quot; ^ Int.toString sid,
   to=&quot;MainChain&quot;,
   amount=0,
   pubkey=&quot;ANCHOR&quot;,
   txSig=Int.toString(hashBlock(mkShardBlock(sbid,sprev,diff,txr)))};

fun mkMainBlock(bid:int, pHash:string, diff:int, txid:int,
                txr:Transaction, mw:Wallet, np:NetworkParameter,
                mi:MachineIdentity, sid:int, sbid:int, sprev:string) : Block =
  {ID=bid,
   prevBlockHash=pHash,
   BlockchainDiffTarget=diff,
   txList=mkDepositTx(txid,mw,np,mi)::txr::(mkShardAnchorTx(sid,sbid,sprev,diff,txr)::[])};

fun nextMainPrevHash(pHash:string, b:Block) : string =
  pHash ^ Int.toString(hashBlock b);

fun blockHashString(b:Block) : string =
  Int.toString(hashBlock b);</layout>
