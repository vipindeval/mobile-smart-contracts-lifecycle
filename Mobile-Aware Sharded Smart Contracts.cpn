          <ml id="ID1449850292">fun hashBlock(b : Block) = hash(
Int.toString(#ID b) ^
#prevBlockHash b ^
Int.toString(#BlockchainDiffTarget b) ^
Int.toString(#ID (hd(#txList b)))
);
            <layout>fun hashBlock(b : Block) = hash(
Int.toString(#ID b) ^
#prevBlockHash b ^
Int.toString(#BlockchainDiffTarget b) ^
Int.toString(#ID (hd(#txList b)))
);</layout>
